import streamlit as st
from reportlab.lib import colors
from reportlab.lib.pagesizes import letter
from reportlab.lib.styles import ParagraphStyle, getSampleStyleSheet
from reportlab.platypus import Paragraph, SimpleDocTemplate, Spacer, Table, TableStyle

# --- CONFIGURATION DE L'APPLICATION (DOIT ÊTRE EN PREMIER) ---
st.set_page_config(page_title="Souniou NATTE", page_icon="💰", layout="wide")


# --- INITIALISATION DE LA BASE DE DONNÉES ---
def init_db():
    conn = sqlite3.connect("tontine_data.db")
    cursor = conn.cursor()

    cursor.execute("""
        CREATE TABLE IF NOT EXISTS membres (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            nom TEXT NOT NULL,
            telephone TEXT,
            date_inscription TEXT
        )
    """)

    cursor.execute("""
        CREATE TABLE IF NOT EXISTS cotisations (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            membre_id INTEGER,
            montant REAL,
            date_paiement TEXT,
            statut TEXT,
            FOREIGN KEY (membre_id) REFERENCES membres(id)
        )
    """)
    conn.commit()
    conn.close()


init_db()


# --- FONCTIONS UTILITAIRES SQLITE ---
def run_query(query, params=()):
    with sqlite3.connect("tontine_data.db") as conn:
        return pd.read_sql_query(query, conn, params=params)


def run_action(query, params=()):
    with sqlite3.connect("tontine_data.db") as conn:
        cursor = conn.cursor()
        cursor.execute(query, params)
        conn.commit()


# --- FONCTION DE GÉNÉRATION DE PDF ---
def generer_pdf(df, titre_document):
    """Génère un fichier PDF soigné à partir d'un DataFrame Pandas"""
    buffer = io.BytesIO()
    doc = SimpleDocTemplate(
        buffer,
        pagesize=letter,
        rightMargin=30,
        leftMargin=30,
        topMargin=30,
        bottomMargin=30,
    )
    elements = []

    styles = getSampleStyleSheet()
    title_style = ParagraphStyle(
        "TitleStyle",
        parent=styles["Heading1"],
        fontSize=18,
        leading=22,
        textColor=colors.HexColor("#1E3A8A"),
        spaceAfter=15,
    )
    date_style = ParagraphStyle(
        "DateStyle",
        parent=styles["Normal"],
        fontSize=10,
        textColor=colors.gray,
        spaceAfter=20,
    )
    cell_style = ParagraphStyle("CellStyle", parent=styles["Normal"], fontSize=9)
    header_style = ParagraphStyle(
        "HeaderStyle",
        parent=styles["Normal"],
        fontSize=10,
        textColor=colors.white,
        fontName="Helvetica-Bold",
    )

    elements.append(Paragraph(titre_document, title_style))
    elements.append(
        Paragraph(
            f"Généré le : {datetime.now().strftime('%d/%m/%Y %H:%M')}",
            date_style,
        )
    )
    elements.append(Spacer(1, 10))

    data = []
    data.append([Paragraph(str(col), header_style) for col in df.columns])

    for _, row in df.iterrows():
        ligne = []
        for val in row:
            if isinstance(val, (int, float)):
                val_str = f"{val:,}".replace(",", " ")
            else:
                val_str = str(val)
            ligne.append(Paragraph(val_str, cell_style))
        data.append(ligne)

    tableau_pdf = Table(data, hAlign="LEFT")
    style_table = TableStyle([
        ("BACKGROUND", (0, 0), (-1, 0), colors.HexColor("#1E3A8A")),
        ("ALIGN", (0, 0), (-1, -1), "LEFT"),
        ("VALIGN", (0, 0), (-1, -1), "MIDDLE"),
        ("BOTTOMPADDING", (0, 0), (-1, 0), 8),
        ("TOPPADDING", (0, 0), (-1, 0), 8),
        ("INNERGRID", (0, 0), (-1, -1), 0.5, colors.lightgrey),
        ("BOX", (0, 0), (-1, -1), 1, colors.HexColor("#1E3A8A")),
    ])

    for i in range(1, len(data)):
        if i % 2 == 0:
            style_table.add("BACKGROUND", (0, i), (-1, i), colors.HexColor("#F3F4F6"))

    tableau_pdf.setStyle(style_table)
    elements.append(tableau_pdf)

    doc.build(elements)
    buffer.seek(0)
    return buffer


