        st.rerun()

choix = st.session_state["page_active"]


# --- LOGIQUE DES PAGES ---

# 1. TABLEAU DE BORD (Liste des membres uniquement en PDF)
if choix == "Tableau de bord":
    st.subheader("📊 État Général de la Tontine")

    total_membres = run_query("SELECT COUNT(*) as total FROM membres").iloc[0][
        "total"
    ]
    total_caisse = run_query(
        "SELECT SUM(montant) as total FROM cotisations WHERE statut='Payé'"
    ).iloc[0]["total"]
    total_caisse = total_caisse if total_caisse else 0.0

    col1, col2 = st.columns(2)
    col1.metric("Nombre total de membres", f"{total_membres} membres")
    col2.metric("Total en Caisse", f"{total_caisse:,} FCFA".replace(",", " "))

    st.markdown("---")
    st.write("### 👥 Liste des Membres Inscrits")
    df_membres = run_query(
        "SELECT id as 'ID', nom as 'Nom Complet', telephone as 'Téléphone', date_inscription as 'Date Inscription' FROM membres"
    )

    if not df_membres.empty:
        st.dataframe(df_membres, use_container_width=True)

        # Bouton PDF uniquement
        pdf_membres = generer_pdf(df_membres, "Liste des Membres Inscrits")
        st.download_button(
            label="📥 Télécharger la liste des membres (PDF)",
            data=pdf_membres,
            file_name=f"liste_membres_{datetime.now().strftime('%Y%m%d')}.pdf",
            mime="application/pdf",
        )
    else:
        st.info("Aucun membre inscrit pour le moment.")


# 2. S'INSCRIRE MEMBRE
elif choix == "S'inscrire Membre":
    st.subheader("👤 Ajouter un nouveau membre")

    with st.form("form_membre", clear_on_submit=True):
        nom = st.text_input("Nom et Prénom du membre :")
        telephone = st.text_input("Numéro de Téléphone :")
        soumettre = st.form_submit_button("Enregistrer le membre")

        if soumettre:
            if nom:
                date_actuelle = datetime.now().strftime("%Y-%m-%d %H:%M")
                run_action(
                    "INSERT INTO membres (nom, telephone, date_inscription) VALUES (?, ?, ?)",
                    (nom, telephone, date_actuelle),
                )
                st.success(f"🎉 {nom} a été inscrit avec succès !")
                st.rerun()
            else:
                st.error("Le nom est obligatoire.")


# 3. ENREGISTRER UNE COTISATION
elif choix == "Enregistrer une Cotisation":
    st.subheader("💵 Encaisser une cotisation")

    df_membres = run_query("SELECT id, nom FROM membres")

    if df_membres.empty:
        st.warning(
            "Veuillez d'abord inscrire des membres avant d'enregistrer des cotisations."
        )
    else:
        liste_membres = {
            row["nom"]: row["id"] for _, row in df_membres.iterrows()
        }

        with st.form("form_cotisation", clear_on_submit=True):
            membre_selectionne = st.selectbox(
                "Sélectionner le membre :", list(liste_membres.keys())
            )
            montant = st.number_input(
                "Montant de la cotisation (FCFA) :", min_value=0, step=500
            )
            statut = st.selectbox("Statut :", ["Payé", "Avance", "Retard"])
            soumettre_cotisation = st.form_submit_button("Valider le paiement")

            if soumettre_cotisation:
                membre_id = liste_membres[membre_selectionne]
                date_paiement = datetime.now().strftime("%Y-%m-%d %H:%M")

                run_action(
                    "INSERT INTO cotisations (membre_id, montant, date_paiement, statut) VALUES (?, ?, ?, ?)",
                    (membre_id, montant, date_paiement, statut),
                )
                st.success(
                    f"✅ Cotisation de {montant:,} FCFA enregistrée pour {membre_selectionne} !".replace(
                        ",", " "
                    )
                )


# 4. HISTORIQUE ET RAPPORTS (Téléchargements uniquement en PDF)
elif choix == "Historique et rapports":
    st.subheader("📜 Historique de toutes les transactions")

    query_historique = """
        SELECT c.id as 'ID Transaction', m.nom as 'Nom du Membre', c.montant as 'Montant (FCFA)',
               c.date_paiement as 'Date & Heure', c.statut as 'Statut'
        FROM cotisations c
        JOIN membres m ON c.membre_id = m.id
        ORDER BY c.date_paiement DESC
    """
    df_transactions = run_query(query_historique)

    if not df_transactions.empty:
        total_montant = df_transactions["Montant (FCFA)"].sum()

        ligne_total = pd.DataFrame({
            "ID Transaction": ["TOTAL"],
            "Nom du Membre": ["-"],
            "Montant (FCFA)": [total_montant],
            "Date & Heure": ["-"],
            "Statut": ["-"],
        })

        df_affichage = pd.concat(
            [df_transactions, ligne_total], ignore_index=True
        )
        st.dataframe(df_affichage, use_container_width=True)

        # Actions de correction
        st.markdown("---")
        st.write("### ✏️ Corriger une erreur de saisie")
        liste_ids = df_transactions["ID Transaction"].tolist()

        col_select, col_btn = st.columns([2, 1])
        with col_select:
            id_a_supprimer = st.selectbox(
                "Sélectionner l'ID de la transaction erronée à effacer :",
                liste_ids,
            )
        with col_btn:
            st.write("##")
            if st.button("🗑️ Annuler cette cotisation", type="secondary"):
                run_action(
                    "DELETE FROM cotisations WHERE id = ?",
                    (int(id_a_supprimer),),
                )
                st.success(
                    f"La cotisation N°{id_a_supprimer} a été retirée de l'historique."
                )
                st.rerun()

        st.markdown("---")

        # Bouton PDF pour l'historique global (Pas de CSV)
        pdf_hist = generer_pdf(df_affichage, "Historique des Cotisations")
        st.download_button(
            label="📥 Télécharger l'historique des transactions (PDF)",
            data=pdf_hist,
            file_name=f"historique_tontine_{datetime.now().strftime('%Y%m%d')}.pdf",
            mime="application/pdf",
        )
    else:
        st.info("Aucune transaction enregistrée.")

    st.markdown("---")
    st.subheader("📊 Total des cotisations par membre")

    query_par_membre = """
        SELECT m.nom as 'Nom du Membre', SUM(c.montant) as 'Total Cotisé (FCFA)'
        FROM cotisations c
        JOIN membres m ON c.membre_id = m.id
        WHERE c.statut = 'Payé'
        GROUP BY m.id, m.nom
        ORDER BY SUM(c.montant) DESC
    """
    df_membres_total = run_query(query_par_membre)

    if not df_membres_total.empty:
        st.dataframe(df_membres_total, use_container_width=True)

        # Bouton PDF pour la situation des membres (Pas de CSV)
        pdf_membres_tot = generer_pdf(
            df_membres_total, "Total des Cotisations par Membre"
        )
        st.download_button(
            label="📥 Télécharger le rapport de cotisations par membre (PDF)",
            data=pdf_membres_tot,
            file_name=f"rapport_par_membre_{datetime.now().strftime('%Y%m%d')}.pdf",
            mime="application/pdf",
        )
    else:
        st.info("Aucun cumul disponible.")


# 5. GÉRER LES MEMBRES
elif choix == "Gérer les membres":
    st.subheader("⚙️ Administration des Membres")

    df_membres = run_query("SELECT id, nom, telephone FROM membres")

    if df_membres.empty:
        st.info("Aucun membre enregistré à supprimer.")
    else:
        liste_membres = {
            row["nom"]: row["id"] for _, row in df_membres.iterrows()
        }

        st.write("### 🚨 Supprimer un membre")
        st.warning(
            "Attention : Supprimer un membre effacera également TOUTES ses cotisations associées de manière définitive."
        )

        membre_a_supprimer = st.selectbox(
            "Sélectionner le membre à supprimer :", list(liste_membres.keys())
        )
        membre_id = liste_membres[membre_a_supprimer]

        confirmation = st.checkbox(
            f"Je confirme vouloir supprimer définitivement {membre_a_supprimer} et tout son historique."
        )

        if st.button("❌ Supprimer le membre", type="primary"):
            if confirmation:
                run_action(
                    "DELETE FROM cotisations WHERE membre_id = ?", (membre_id,)
                )
                run_action("DELETE FROM membres WHERE id = ?", (membre_id,))
                st.success(
                    f"💥 {membre_a_supprimer} et ses cotisations ont été supprimés avec succès."
                )
                st.rerun()
            else:
                st.error(
                    "Veuillez cocher la case de confirmation avant de procéder à la suppression."
                )  
